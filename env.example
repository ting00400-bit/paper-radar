# paper-radar environment — 複製成 .env，填入自己的值。
# run.sh / redeploy.sh / notify_*.sh / monitor_r2.sh 會 `source .env` 載入。
# .env 已被 .gitignore 忽略，切勿提交真實 token。

# --- Cloudflare（wrangler pages deploy / D1 / R2 用）-------------------------
# Pages:Edit + D1:Edit + Workers R2 Storage:Edit（依需要的功能勾選）
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# 帳號 ID（Cloudflare dashboard 右側可查）
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# --- ntfy 推播（notify_digest.py / notify_pending.py / monitor_r2.py 用）----
# ntfy server 的存取 token（若 topic 需授權）
NTFY_TOKEN=your-ntfy-token
# ntfy server 基底 URL（不含 topic）。預設 https://ntfy.example.com
NTFY_BASE=https://ntfy.example.com
# ntfy topic 名稱。預設 paper-radar
NTFY_TOPIC=paper-radar
